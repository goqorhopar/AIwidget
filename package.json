{
  "name": "neuro-sales-widget",
  "version": "2.0.0",
  "description": "Interactive AI sales chatbot widget with GPT-4o integration, voice recognition, and Telegram notifications",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest --coverage --detectOpenHandles --forceExit",
    "lint": "eslint server/**/*.js public/**/*.js tests/**/*.js",
    "docker:build": "docker build -t neuro-sales-widget:latest .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down"
  },
  "keywords": [
    "sales",
    "chatbot",
    "gpt-4o",
    "voice-recognition",
    "telegram",
    "widget",
    "lead-generation",
    "ai",
    "openai"
  ],
  "author": "lidorubov.net",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/goqorhopar/neuro-sales-widget.git"
  },
  "bugs": {
    "url": "https://github.com/goqorhopar/neuro-sales-widget/issues"
  },
  "homepage": "https://github.com/goqorhopar/neuro-sales-widget#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2",
    "openai": "^4.20.0",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
