# ===========================
# Neuro Sales Widget Configuration
# ===========================

# ---------------------------
# OpenAI API Configuration
# ---------------------------
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use (gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# Temperature controls randomness (0.0 - 1.0)
# Lower = more focused, Higher = more creative
OPENAI_TEMPERATURE=0.3

# ---------------------------
# Telegram Bot Configuration
# ---------------------------
# Create bot via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Get chat ID via @userinfobot or similar
# Multiple IDs can be comma-separated (e.g., 123456789,987654321)
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ---------------------------
# Server Configuration
# ---------------------------
PORT=3000
NODE_ENV=development

# Log level: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO

# ---------------------------
# CORS Configuration
# ---------------------------
# Allowed origins (use * for development, specific domain for production)
CORS_ORIGIN=*

# ---------------------------
# Company Configuration
# ---------------------------
COMPANY_NAME=lidorubov.net
SALES_SCRIPT_VERSION=2.0
